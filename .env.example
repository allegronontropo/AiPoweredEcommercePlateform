POSTGRES_USER=compintel
POSTGRES_PASSWORD=compintel
POSTGRES_DB=compintel
DATABASE_URL=postgres://compintel:compintel@postgres:5432/compintel
OPENAI_API_KEY=your_openai_api_key_here
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
# Webhook URL for enrichment (will be updated after activating workflow 02)
WEBHOOK_ENRICHMENT_URL=http://localhost:5678/webhook/enrich

# Email settings (if you want to use env vars instead of SMTP credential)
SMTP_FROM=your_email
ALERT_EMAIL=your_email

# Optional: SMTP via environment variables (if you prefer not to use credential)
N8N_SMTP_HOST=smtp.gmail.com
N8N_SMTP_PORT=587
N8N_SMTP_USER=your_sender_email@gmail.com
N8N_SMTP_PASS=your_smtp_password_here
N8N_SMTP_SENDER="Competitive Intel <your_mail@gmail.com>"
N8N_SMTP_SSL=false
N8N_SMTP_STARTTLS=true