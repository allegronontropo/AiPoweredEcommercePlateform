        "postgres": {
          "id": "replace_me",
          "name": "Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO sentiment_scores (product_id, score, label, model_name) VALUES ($1, LEAST(1, GREATEST(-1, $2::numeric)), CASE WHEN LEAST(1, GREATEST(-1, $2::numeric)) > 0.2 THEN 'positive' WHEN LEAST(1, GREATEST(-1, $2::numeric)) < -0.2 THEN 'negative' ELSE 'neutral' END, 'deterministic-model');",
        "additionalFields": {
          "queryParams": "={{[$json.id, $json.sentiment_score]}}"
        }
      },
