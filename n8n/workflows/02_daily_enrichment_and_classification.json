          "name": "Postgres"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const text = `${$json.title} ${$json.description || ''}`.toLowerCase();\nlet category = 'other';\nif (/(phone|laptop|tablet|camera|headphone)/.test(text)) category = 'electronics';\nif (/(shirt|shoe|jacket|dress)/.test(text)) category = 'fashion';\nconst base = [...text].reduce((acc, ch) => acc + ch.charCodeAt(0), 0);\nconst normalized = ((base % 200) - 100) / 100;\nconst sentiment_score = Math.max(-1, Math.min(1, Number(normalized.toFixed(3))));\nreturn [{ json: { ...$json, inferred_category: category, sentiment_score } }];"
      },
      "id": "code_classify",
      "name": "Classify + Simulate Sentiment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        670,
        260
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE products SET category = COALESCE(category, $1), updated_at = NOW() WHERE id = $2;",
        "additionalFields": {
          "queryParams": "={{[$json.inferred_category, $json.id]}}"
        }
      },
      "id": "pg_update_category",
      "name": "Update Category",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        920,
        200
